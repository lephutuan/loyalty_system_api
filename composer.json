{
  "name": "task-week-1/loyalty-system",
  "description": "Symfony API Platform loyalty system",
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "ext-bcmath": "*",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "php": "^8.3",
    "api-platform/api-pack": "^1.4",
    "doctrine/doctrine-bundle": "^2.12",
    "doctrine/orm": "^3.2",
    "doctrine/doctrine-migrations-bundle": "^3.4",
    "symfony/cache": "^7.2",
    "symfony/console": "^7.2",
    "symfony/dotenv": "^7.2",
    "symfony/framework-bundle": "^7.2",
    "symfony/http-foundation": "^7.2",
    "symfony/runtime": "^7.2",
    "symfony/serializer": "^7.2",
    "symfony/property-access": "^7.2",
    "symfony/property-info": "^7.2",
    "symfony/validator": "^7.2",
    "symfony/yaml": "^7.2"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.11",
    "phpstan/phpstan-doctrine": "^1.5",
    "phpstan/phpstan-symfony": "^1.4",
    "phpunit/phpunit": "^11.5",
    "symfony/maker-bundle": "^1.61",
    "symfony/phpunit-bridge": "^7.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": [
      "phpunit"
    ],
    "race:redeem": [
      "node scripts/race-load-test.js redeem-race"
    ],
    "race:redeem:loop": [
      "node scripts/race-load-test.js redeem-race-loop"
    ],
    "race:transactions": [
      "node scripts/race-load-test.js transaction-burst"
    ],
    "stan": [
      "phpstan analyse src tests --level=9"
    ],
    "lint": [
      "php -l src/Kernel.php"
    ]
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true,
    "platform": {
      "php": "8.3.0"
    }
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "7.2.*"
    }
  }
}
