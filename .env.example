# App
APP_ENV=dev
APP_SECRET=change_me

# Database connection used by Symfony
DATABASE_URL="mysql://app:app@mysql:3306/loyalty?serverVersion=8.0&charset=utf8mb4"

# MySQL container
MYSQL_DATABASE=loyalty
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_ROOT_PASSWORD=root

# phpMyAdmin container
PMA_HOST=mysql
PMA_PORT=3306
