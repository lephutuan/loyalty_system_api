    {
      "name": "Get Wallet Inquiry",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.balance) {",
              "  pm.environment.set('lastWalletBalance', json.balance);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/members/{{memberId}}/wallet",
          "host": ["{{baseUrl}}"],
          "path": ["members", "{{memberId}}", "wallet"]
        },
        "description": "Truy van vi diem cua member."
      },
      "response": []
