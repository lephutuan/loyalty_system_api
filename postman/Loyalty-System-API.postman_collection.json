    {
      "name": "Create Transaction",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.transaction_id) {",
              "  pm.environment.set('lastTransactionId', json.transaction_id);",
              "}",
              "if (json.points_earned) {",
              "  pm.environment.set('lastPointsEarned', json.points_earned);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"member_id\": {{memberId}},\n  \"amount\": \"{{amount}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/transactions",
          "host": ["{{baseUrl}}"],
          "path": ["transactions"]
        },
        "description": "Tao giao dich va cong diem theo ty le 1%."
      },
      "response": []
    },
    {
      "name": "Create Redemption",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.redemption_id) {",
              "  pm.environment.set('lastRedemptionId', json.redemption_id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
